{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Categorias de productos",
    "description": "Organize your content into categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "description": {
      "type": "text"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "inversedBy": "categories"
    },
    "icons": {
      "type": "dynamiczone",
      "components": [
        "shared.icons"
      ]
    },
    "descriptionShort": {
      "type": "string"
    },
    "image": {
      "type": "component",
      "component": "shared.image",
      "repeatable": false
    }
  }
}
