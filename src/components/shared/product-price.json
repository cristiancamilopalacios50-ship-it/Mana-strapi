{
  "collectionName": "components_shared_product_prices",
  "info": {
    "displayName": "Precio y presentación"
  },
  "options": {},
  "attributes": {
    "price": {
      "type": "integer"
    },
    "presentation": {
      "type": "string"
    },
    "weight": {
      "type": "string",
      "required": true,
      "regex": "^\\d+(\\.\\d+)?$"
    },
    "shippingMode": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "block",
        "linear"
      ]
    },
    "unitsPerBlock": {
      "type": "integer"
    }
  },
  "config": {}
}
